{
  "name": "sda-chms",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6.0.3",
      "@types/bun": "^1.3.14",
      "drizzle-orm": "^0.45.2",
      "hono": "^4.12.27",
      "@faker-js/faker": "^10.5.0"
    }
  },
  "type": "module",
  "scripts": {
    "check": "biome check --write .",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @sda-chms/db db:push",
    "db:studio": "turbo -F @sda-chms/db db:studio",
    "db:generate": "turbo -F @sda-chms/db db:generate",
    "db:migrate": "turbo -F @sda-chms/db db:migrate",
    "prepare": "husky"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@sda-chms/env": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@playwright/test": "^1.61.1",
    "@sda-chms/config": "workspace:*",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.10.0",
    "typescript": "catalog:",
    "ultracite": "7.8.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.13"
}
